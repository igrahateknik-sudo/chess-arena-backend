generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  username            String                   @unique @db.VarChar(30)
  email               String                   @unique @db.VarChar(255)
  password_hash       String
  elo                 Int?                     @default(800)
  games_played        Int?                     @default(0)
  wins                Int?                     @default(0)
  losses              Int?                     @default(0)
  draws               Int?                     @default(0)
  title               String?                  @db.VarChar(5)
  country             String?                  @default("ID") @db.VarChar(3)
  avatar_url          String?
  verified            Boolean?                 @default(false)
  verify_token        String?
  reset_token         String?
  online              Boolean?                 @default(false)
  socket_id           String?
  trust_score         Int?                     @default(100)
  flagged             Boolean?                 @default(false)
  flagged_reason      String?
  flagged_at          DateTime?                @db.Timestamptz(6)
  is_admin            Boolean?                 @default(false)
  created_at          DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?                @default(now()) @db.Timestamptz(6)
  last_ip             String?
  anticheat_actions   AntiCheatAction[]
  reviewed_appeals    Appeal[]                 @relation("admin_reviews")
  appeals             Appeal[]                 @relation("user_appeals")
  collusion_a         CollusionFlag[]          @relation("collusion_a")
  collusion_b         CollusionFlag[]          @relation("collusion_b")
  fingerprints        DeviceFingerprint[]
  elo_history         EloHistory[]
  black_games         Game[]                   @relation("black_player")
  white_games         Game[]                   @relation("white_player")
  audit_logs          MoveAuditLog[]
  multi_account_a     MultiAccountFlag[]       @relation("user_a")
  multi_account_b     MultiAccountFlag[]       @relation("user_b")
  notifications       Notification[]
  security_events     SecurityEvent[]
  registrations       TournamentRegistration[]
  tournaments_created Tournament[]             @relation("tournament_creator")
  tournaments_won     Tournament[]             @relation("tournament_winner")
  transactions        Transaction[]
  wallet              Wallet?

  @@index([username])
  @@index([email])
  @@index([elo(sort: Desc)])
  @@index([flagged])
  @@index([trust_score])
  @@index([is_admin])
  @@map("users")
}

model Wallet {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String    @unique @db.Uuid
  balance    BigInt?   @default(0)
  locked     BigInt?   @default(0)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Transaction {
  id                    String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id               String?   @db.Uuid
  type                  String    @db.VarChar(30)
  amount                BigInt
  balance_after         BigInt?
  status                String?   @default("pending") @db.VarChar(20)
  description           String?
  reference             String?   @unique @db.VarChar(100)
  midtrans_order_id     String?   @unique
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
  updated_at            DateTime? @default(now()) @db.Timestamptz(6)
  game_id               String?   @db.Uuid
  midtrans_payment_type String?
  midtrans_raw          Json?
  midtrans_va_number    String?
  tournament_id         String?   @db.Uuid
  user                  User?     @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at(sort: Desc)])
  @@map("transactions")
}

model Game {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  white_id          String?             @db.Uuid
  black_id          String?             @db.Uuid
  fen               String?             @default("rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1")
  move_history      Json?               @default("[]")
  status            String?             @default("active") @db.VarChar(20)
  winner            String?             @db.VarChar(10)
  end_reason        String?             @db.VarChar(30)
  time_control      Json
  stakes            BigInt?             @default(0)
  white_elo_before  Int?
  black_elo_before  Int?
  white_elo_after   Int?
  black_elo_after   Int?
  white_time_left   Int?
  black_time_left   Int?
  started_at        DateTime?           @default(now()) @db.Timestamptz(6)
  ended_at          DateTime?           @db.Timestamptz(6)
  anticheat_flags   Json?               @default("[]")
  pgn               String?             @default("")
  anticheat_actions AntiCheatAction[]
  collusion_flags   CollusionFlag[]
  fingerprints      DeviceFingerprint[]
  elo_history       EloHistory[]
  black_player      User?               @relation("black_player", fields: [black_id], references: [id])
  white_player      User?               @relation("white_player", fields: [white_id], references: [id])
  audit_logs        MoveAuditLog[]
  tournament_games  TournamentGame[]

  @@index([white_id, black_id])
  @@index([status])
  @@map("games")
}

model Tournament {
  id                 String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name               String                   @db.VarChar(100)
  description        String?
  format             String                   @db.VarChar(20)
  time_control       Json
  prize_pool         BigInt?                  @default(0)
  status             String?                  @default("upcoming") @db.VarChar(20)
  starts_at          DateTime                 @db.Timestamptz(6)
  ends_at            DateTime?                @db.Timestamptz(6)
  created_at         DateTime?                @default(now()) @db.Timestamptz(6)
  created_by         String?                  @db.Uuid
  entry_fee          BigInt?                  @default(0)
  max_elo            Int?                     @default(9999)
  max_players        Int?                     @default(64)
  min_elo            Int?                     @default(0)
  prize_distribution Json?                    @default("[50, 30, 20]")
  winner_id          String?                  @db.Uuid
  tournament_games   TournamentGame[]
  registrations      TournamentRegistration[]
  creator            User?                    @relation("tournament_creator", fields: [created_by], references: [id])
  winner             User?                    @relation("tournament_winner", fields: [winner_id], references: [id])

  @@map("tournaments")
}

model TournamentRegistration {
  id            String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tournament_id String     @db.Uuid
  user_id       String     @db.Uuid
  paid          Boolean?   @default(false)
  score         Decimal?   @default(0) @db.Decimal(5, 1)
  registered_at DateTime?  @default(now()) @db.Timestamptz(6)
  tournament    Tournament @relation(fields: [tournament_id], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([tournament_id, user_id])
  @@map("tournament_registrations")
}

model TournamentGame {
  id            String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tournament_id String?     @db.Uuid
  game_id       String?     @db.Uuid
  round         Int?
  board         Int?
  game          Game?       @relation(fields: [game_id], references: [id])
  tournament    Tournament? @relation(fields: [tournament_id], references: [id])

  @@map("tournament_games")
}

model EloHistory {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String    @db.Uuid
  elo_before Int?
  elo_after  Int?
  change     Int?
  game_id    String?   @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  game       Game?     @relation(fields: [game_id], references: [id])
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at(sort: Desc)])
  @@map("elo_history")
}

model Notification {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String    @db.Uuid
  type       String?   @db.VarChar(30)
  title      String?
  body       String?
  read       Boolean?  @default(false)
  data       Json?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model MoveAuditLog {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  game_id       String?   @db.Uuid
  user_id       String?   @db.Uuid
  move_seq      Int
  san           String?
  server_ts     BigInt?
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  fen_after     String?
  from_sq       String?
  time_left     Int?
  time_taken_ms Int?
  to_sq         String?
  game          Game?     @relation(fields: [game_id], references: [id])
  user          User?     @relation(fields: [user_id], references: [id])

  @@index([game_id])
  @@index([user_id])
  @@index([game_id, move_seq])
  @@index([created_at(sort: Desc)])
  @@map("move_audit_log")
}

model AntiCheatAction {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String?   @db.Uuid
  game_id    String?   @db.Uuid
  action     String    @db.VarChar(20)
  reason     String?
  flags      String?
  score      Int?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  game       Game?     @relation(fields: [game_id], references: [id])
  user       User?     @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at(sort: Desc)])
  @@index([action])
  @@map("anticheat_actions")
}

model DeviceFingerprint {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id          String    @db.Uuid
  fingerprint_hash String
  ip_hash          String
  ua_hash          String
  game_id          String?   @db.Uuid
  seen_at          DateTime? @default(now()) @db.Timestamptz(6)
  game             Game?     @relation(fields: [game_id], references: [id])
  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, fingerprint_hash])
  @@index([fingerprint_hash])
  @@index([user_id])
  @@index([seen_at(sort: Desc)])
  @@map("device_fingerprints")
}

model MultiAccountFlag {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id_a        String    @db.Uuid
  user_id_b        String    @db.Uuid
  fingerprint_hash String
  detected_at      DateTime? @default(now()) @db.Timestamptz(6)
  review_note      String?
  reviewed         Boolean?  @default(false)
  reviewed_at      DateTime? @db.Timestamptz(6)
  reviewed_by      String?   @db.Uuid
  verdict          String?   @db.VarChar(20)
  user_a           User      @relation("user_a", fields: [user_id_a], references: [id], onDelete: Cascade)
  user_b           User      @relation("user_b", fields: [user_id_b], references: [id], onDelete: Cascade)

  @@unique([user_id_a, user_id_b, fingerprint_hash])
  @@index([user_id_a])
  @@index([user_id_b])
  @@index([reviewed])
  @@map("multi_account_flags")
}

model CollusionFlag {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  game_id     String?   @db.Uuid
  user_id_a   String    @db.Uuid
  user_id_b   String    @db.Uuid
  detected_at DateTime? @default(now()) @db.Timestamptz(6)
  gift_flags  String?
  pair_flags  String?
  pair_score  Int?      @default(0)
  pair_stats  String?
  review_note String?
  reviewed    Boolean?  @default(false)
  reviewed_at DateTime? @db.Timestamptz(6)
  reviewed_by String?   @db.Uuid
  verdict     String?   @db.VarChar(20)
  game        Game?     @relation(fields: [game_id], references: [id])
  user_a      User      @relation("collusion_a", fields: [user_id_a], references: [id], onDelete: Cascade)
  user_b      User      @relation("collusion_b", fields: [user_id_b], references: [id], onDelete: Cascade)

  @@index([user_id_a])
  @@index([user_id_b])
  @@index([reviewed])
  @@index([detected_at(sort: Desc)])
  @@map("collusion_flags")
}

model Appeal {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id        String    @db.Uuid
  reason         String
  evidence       String?
  status         String?   @default("pending") @db.VarChar(20)
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  admin_note     String?
  flag_reason_at String?
  reviewed_at    DateTime? @db.Timestamptz(6)
  reviewed_by    String?   @db.Uuid
  trust_at       Int?
  admin          User?     @relation("admin_reviews", fields: [reviewed_by], references: [id])
  user           User      @relation("user_appeals", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@index([created_at(sort: Desc)])
  @@map("appeals")
}

model SecurityEvent {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  event_type String    @db.VarChar(60)
  user_id    String?   @db.Uuid
  details    String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  user       User?     @relation(fields: [user_id], references: [id])

  @@index([event_type])
  @@index([user_id])
  @@index([created_at(sort: Desc)])
  @@map("security_events")
}
